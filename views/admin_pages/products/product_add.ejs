<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>EDEN | Thêm sản phẩm</title>
    <style>
      .maincontent { padding: 20px; max-width: 960px; margin: 0 auto; }
      .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .row1 { display: grid; grid-template-columns: 1fr; gap: 16px; }
      label { display: block; margin: 8px 0 4px; font-weight: 600; }
      input, textarea, select { width: 100%; padding: 8px; }
      .actions { display: flex; gap: 8px; margin-top: 16px; }
      .btn { display: inline-block; padding: 6px 10px; border-radius: 4px; text-decoration: none; color: #fff; }
      .btn-secondary { background: #6c757d; }
      .btn-primary { background: #007bff; }
    </style>
  </head>
  <body>
    <div class="maincontent">
      <h2>Thêm sản phẩm</h2>

      <form action="/admin/products/add" method="post" enctype="multipart/form-data">

        <div class="row2">
          <div>
            <label for="product_name">Tên sản phẩm</label>
            <input id="product_name" name="product_name" required />
          </div>
          <div>
            <label for="price">Giá (₫)</label>
            <input id="price" name="price" type="number" min="0" step="1000" required />
          </div>
        </div>

        <div class="row2">
          <div>
            <label for="stock_quantity">Số lượng kho</label>
            <input id="stock_quantity" name="stock_quantity" type="number" min="0" required />
          </div>
          <div>
            <label for="category_id">Danh mục</label>
            <select id="category_id" name="category_id">
              <option value="">-- Không chọn --</option>
              <% categories.forEach(function(c) { %>
                <option value="<%= c.category_id %>"><%= c.category_name %></option>
              <% }); %>
            </select>
          </div>
        </div>

        <div class="row1">
          <div>
            <label for="description">Miêu tả</label>
            <textarea id="description" name="description" rows="4"></textarea>
          </div>
          <div>
            <label for="image">Hình ảnh</label>
            <input id="image" type="file" name="image" accept="image/*" />
          </div>
        </div>

        <div class="actions">
          <a class="btn btn-secondary" href="/admin/products">Hủy</a>
          <button class="btn btn-primary" type="submit">Lưu</button>
        </div>

      </form>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
  <div class="container mt-4">
    <h2><%= title %></h2>
    <a href="/admin/roles/add" class="btn btn-success mb-3">Thêm Nhóm Người Dùng</a>
    <table class="table table-bordered table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>Tên nhóm</th>
          <th>Mô tả</th>
          <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        <% if (roles.length === 0) { %>
          <tr>
            <td colspan="4" class="text-center">Chưa có nhóm người dùng nào</td>
          </tr>
        <% } else { %>
          <% roles.forEach(role => { %>
            <tr>
              <td><%= role.role_id %></td>
              <td><%= role.role_name %></td>
              <td><%= role.description || '' %></td>
              <td>
                <a href="/admin/roles/edit/<%= role.role_id %>" class="btn btn-primary btn-sm me-1">Sửa</a>
                <form action="/admin/roles/delete/<%= role.role_id %>" method="POST" style="display:inline-block;" onsubmit="return confirm('Bạn có chắc muốn xóa nhóm này?');">
                  <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <title>EDEN | Giỏ Hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body {
      background: #f8f9fa;
      margin-top: 100px;
    }
    .cart-card {
      border-radius: 15px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      background: #fff;
      padding: 20px;
      margin-bottom: 20px;
    }
    .cart-img {
      max-width: 120px;
      border-radius: 10px;
    }
    .cart-total-box {
      background: #fff;
      padding: 20px;
      border-radius: 15px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .btn-qty {
      border: 1px solid #ccc;
      border-radius: 50%;
      width: 35px;
      height: 35px;
      text-align: center;
      padding: 0;
    }
    .empty-cart {
      text-align: center;
      padding: 50px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h2 class="text-center mb-4">🛒 Giỏ Hàng</h2>

    <% if (cart.length > 0) { %>
      <div class="row">
        <!-- Danh sách sản phẩm -->
        <div class="col-lg-8">
          <% cart.forEach((item, i) => { %>
            <div class="cart-card d-flex align-items-center justify-content-between">
              <div class="d-flex align-items-center">
                <img src="/uploads/<%= item.image %>" class="cart-img me-3">
                <div>
                  <h5><%= item.name %></h5>
                  <p class="text-muted mb-1">Giá: <b><%= item.price_sale.toLocaleString() %> VND</b></p>
                  <p class="mb-0">Thành tiền: 
                    <span class="text-danger fw-bold">
                      <%= item.thanhtien.toLocaleString() %> VND
                    </span>
                  </p>
                </div>
              </div>

              <div class="d-flex align-items-center">
                <a href="/cart/minus/<%= item.id %>" class="btn btn-light btn-qty me-2">
                  <i class="fa fa-minus"></i>
                </a>
                <span class="fw-bold"><%= item.quantity %></span>
                <a href="/cart/plus/<%= item.id %>" class="btn btn-light btn-qty ms-2">
                  <i class="fa fa-plus"></i>
                </a>
              </div>

              <a href="/cart/remove/<%= item.id %>" class="btn btn-outline-danger ms-3">
                <i class="fa fa-trash"></i>
              </a>
            </div>
          <% }) %>
        </div>

        <!-- Tổng tiền -->
        <div class="col-lg-4">
          <div class="cart-total-box">
            <h4>Tổng cộng</h4>
            <h3 class="text-danger"><%= total.toLocaleString() %> VND</h3>
            <hr>
            <div class="d-grid gap-2">
              <a href="/cart/clear" class="btn btn-outline-danger">
                <i class="fa fa-trash"></i> Xóa tất cả
              </a>
              <% if (user) { %>
                <a href="/delivery" class="btn btn-success">
                  <i class="fa fa-truck"></i> Tiến hành thanh toán
                </a>
              <% } else { %>
                <a href="/registers" class="btn btn-warning">
                  <i class="fa fa-user"></i> Đăng ký để tiếp tục
                </a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="empty-cart">
        <img src="/images/empty.png" width="300" class="mb-3">
        <h4>Giỏ hàng của bạn đang trống!</h4>
        <a href="/" class="btn btn-success mt-3">Mua Ngay</a>
      </div>
    <% } %>
  </div>
</body>
</html>

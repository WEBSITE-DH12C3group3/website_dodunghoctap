<!DOCTYPE html>
<html lang="vi">
<head>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* produc CSS */
        .product-image {
            width: 100%;
            height: auto;
            max-height: 300px;
            object-fit: cover;
        }

        .carousel-item {
            transition: transform 1s ease;
            /* 2 giây */
        }
    </style>
    <style>
        .swal2-popup { 
            font-size: 0.9rem !important;
            font-family: Arial, sans-serif;
        }

        .swal2-toast {
            background: #fff;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }
    </style>

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

      <style>
        .swiper {
            width: 100%;
            height: 400px;
        }
        .swiper-wrapper {
            height: 400px;
        }
        .swiper-slide {
            background-color: aquamarine;
            display: flex;                /* phải có dòng này */
            justify-content: center;      /* căn ngang */
            align-items: center;          /* căn dọc */
            background-image: url("https://wallpapers.com/images/hd/blueto-yellow-gradient-abstract-wt4x802da8mmp3br.jpg");
            background-size: cover;       
            background-position: center;  
        }
        .swiper-slide img {
            max-width: 80%;
            max-height: 80%;
            object-fit: contain;          /* giữ nguyên tỉ lệ, không bị cắt */
            display: block;               /* tránh bị inline làm lệch */
            margin: auto;                 /* fallback nếu flex lỗi */
        }

      </style>

</head>
<body>
  <%- include('../partials/header') %>

  <body style="margin-top: 120px;">

    <section class="mymaincontent my-3">
        <div class="container my-3">
            <!-- Banner -->
            <div class="swiper mySwiper">
            <div class="swiper-wrapper">
                <div class="swiper-slide"><img src="https://thresholdresources.wordpress.com/wp-content/uploads/2018/12/office-supplies.jpg" alt="Banner 3"></div>
                <div class="swiper-slide"><img src="https://tse2.mm.bing.net/th/id/OIP.eSOggCcEKqFGGE22iGTiEwHaFj?w=626&h=470&rs=1&pid=ImgDetMain&o=7&rm=3" alt="Banner 3"></div>
                <div class="swiper-slide"><img src="https://thresholdresources.wordpress.com/wp-content/uploads/2018/12/office-supplies.jpg" alt="Banner 3"></div>
                <div class="swiper-slide"><img src="https://thresholdresources.wordpress.com/wp-content/uploads/2018/12/office-supplies.jpg" alt="Banner 3"></div>
            </div>

            <!-- Thêm nút điều khiển nếu muốn -->
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-pagination"></div>
            </div>
            <br>
            <div class="cate-list mb-3">
                <span>
                    <h3 style="color: #3f640b;">Sản Phẩm Nổi Bật</h3>
                </span>
                <hr>
                <div class="row py-4">
                    <div class="large-12 columns">
                        <div class="product-list owl-carousel owl-theme"> <!-- Đặt div này chứa toàn bộ sản phẩm -->
                            
                            <div class="item hover-effect" style="border-radius: 10px; padding: 5px;">
                                <div class="category-icon text-center"> <!-- Thêm class 'text-center' để căn giữa -->
                                    <a href="" class="product-link">
                                        <img src="" alt="hoaxinh" class="img-fluid">
                                        <h6 class="mt-2" style="color: black;"></h6> <!-- Thêm margin-top để tạo khoảng cách giữa ảnh và chữ -->
                                    </a>
                                </div>
                            </div>
                         
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid">
            <div class="row">
                <div class="col">
                    <div class="product-list mb-3">
                        <div class="row text-center">
                            <div class="row text-center">
                              <div class="row text-center">
                                <div class="container">
                                <% for (let catId in catProducts) { %>
                                    <div class="category-block" style="margin-bottom: 60px;"> 
                                    <h2 style="margin-bottom: 20px;"><%= catProducts[catId].category_name %></h2>
                                    <%- include("view_products", { products: catProducts[catId].products }) %>
                                    </div>
                                <% } %>
                                </div>


                              </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
<%- include('../partials/footer') %>
</body>
</html>   
 <script>

     var swiper = new Swiper(".mySwiper", {
         loop: true, // lặp lại vô hạn
         autoplay: {
         delay: 2000, // 3 giây đổi ảnh
         disableOnInteraction: false,
         },
         pagination: {
         el: ".swiper-pagination",
         clickable: true,
         },
         navigation: {
         nextEl: ".swiper-button-next",
         prevEl: ".swiper-button-prev",
         },
         effect: "coverflow", // có thể đổi thành "fade", "cube", "coverflow", "flip"
         speed: 700 // tốc độ chuyển slide (ms)
     });
</script>
